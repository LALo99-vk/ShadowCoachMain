DATABASE_URL=postgresql://user:password@host:5432/db

JWT_USER_SECRET=your_long_random_secret

# Access token lifetime (JWT), default 15m
# ACCESS_TOKEN_EXPIRES=15m
# REFRESH_TOKEN_DAYS=7

NODE_ENV=production
PORT=3000

# Production (Vercel): set to your deployed URL, e.g. https://shadowcoach.vercel.app
# Comma-separated if you use multiple domains. VERCEL_URL is added automatically on Vercel.
CLIENT_URL=https://your-app.vercel.app

# AI
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional Grok fallback
# XAI_API_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
